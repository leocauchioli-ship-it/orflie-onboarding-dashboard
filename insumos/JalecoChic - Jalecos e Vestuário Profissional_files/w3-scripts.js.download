            2024-02-06 | alima
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productMeasureTable: function(){
            mBtn      = $('.js-measure-btn');
            mBtnClose = $('.js-popup-close');
            mPopUp    = $('.js-popup-measureTape');
            backdrop  = $('.js-backdrop');
            
            mBtn.on('click', function(){
                mPopUp.fadeIn(); 
                backdrop.fadeIn();
                // $('html').css('overflow','hidden');
            });
            mBtnClose.on('click', function(){
                mPopUp.fadeOut(); 
                backdrop.fadeOut(); 
                // $('html').css('overflow','auto');
            });
    
            console.log("[[[W3CorpTema]]] productMeasureTable iniciado.");
        },
        


        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - Clear: Both na descricao do produto
            2024-02-19 | alima
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productDescription: function(){
            pDescription = $('.w3-product-content#description article');
            
            pDescription.append('<div style="clear:both;"></div>')
    
            console.log("[[[W3CorpTema]]] pDescription iniciado.");
        },
        
        

        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - Acordeon variacoes
            2024-02-08 | alima
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productVariantAccordion: function(){
            vBtn         = $('.w3-product-info-price .lista_radios li.color > .lista-radios-input');
            vLista       = $('.w3-product-info-price .lista_radios li.color > .lista_radios');
            vBtnMultipla = $('.w3-product-info-price .lista_radios.listaVarMultipla li.color > .labelMultiVariacao');
            
            vBtn.on('click', function(e){
                var nextList = $(this).next(vLista);
            
                if (!nextList.is(':visible')) {
                    vLista.slideUp();
                    nextList.slideDown();
                }
            
                if (nextList.is(':visible')) {
                    e.preventDefault();
                }
            });
            
            vBtnMultipla.on('click', function(e){
                var nextList = $(this).siblings('.lista_radios');

                if (!nextList.is(':visible')) {
                    vLista.slideUp();
                    nextList.slideDown();
                }
            
                if (nextList.is(':visible')) {
                    e.preventDefault();
                }
            });
            
    
            console.log("[[[W3CorpTema]]] productVariantAccordion iniciado.");
        },
  
        
        
        
        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - Textos das variacoes
            2024-02-08 | alima
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productVariantTexts: function(){
            vBtn   = $('.w3-product-info-price .lista-radios-input');
            
            vBtn.each(function() {
                $(this).contents().filter(function() {
                    return this.nodeType === 3 && $.trim(this.nodeValue) !== ''; // Seleciona apenas os textNodes nao vazios
                }).wrap('<span></span>'); // Envolve cada texto encontrado em um <span>
            });
            
    
            console.log("[[[W3CorpTema]]] productVariantTexts iniciado.");
        },


  
        
        
        
        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - calculo do frete
            2024-02-23 | tneves
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productfrete: function(){
            var quantity = 1;
            $('.zip-code-mask').mask('00000-000');
            $('.shipping-form').on('submit', function(event){
                event.preventDefault();
                console.log("[[[W3CorpTema]]] productfrete iniciado.");

                let variant  = $('#form_comprar').find('input[type="hidden"][name="variacao"]');
                //let url      = $('#shippingSimulatorButton').data('url'); 
                let url      = $('#shippingSimulatorButton').attr('data-url');                 
                let cep      = $('input', this).val().split('-');

                if (jQuery('#quant:visible').is(':visible')) {
                    quantity = jQuery('#quant:visible').val();
                }

                if(variant.length && variant.val() === ''){
                    $('.product-shipping .result').addClass('loaded').html(`<div class="error-message">Por favor, selecione as varia&ccedil;&otilde;es antes de calcular o frete.</div>`);
                    return;
                }

                variant = variant.val() || 0;

                url = url.replace('cep1=%s', `cep1=${cep[0]}`  )
                         .replace('cep2=%s', `cep2=${cep[1]}`  )
                         .replace('acao=%s', `acao=${variant}` )
                         .replace('dade=%s', `dade=${quantity}`);


                console.log("[[[W3CorpTema]]] productfrete - AJAX - Aguarde status");
                $('.product-shipping .result').removeClass('loaded').addClass('loading').html('Carregando fretes...');

                /* Validate zip code first using viacep web service */
                $.ajax({
                    'url'      : `https://viacep.com.br/ws/${cep[0]+cep[1]}/json/`,
                    'method'   : 'get',
                    'dataType' : 'json',
                    'success'  : function (viacepResponse) {

                        if(viacepResponse.erro){
                            
                            console.log("[[[W3CorpTema]]] productfrete - AJAX - erro na validacao do cep.");

                            let message = 'Cep inv&aacute;lido. Verifique e tente novamente.'
                            $('.product-shipping .result').removeClass('loading').addClass('loaded').html(`<div class="error-message">${message}</div>`);

                            return;

                        }
                        console.log("[[[W3CorpTema]]] productfrete - AJAX - Segundo AJAX.");
                        $.ajax({
                            'url'    : url,
                            'method' : 'get',
                            'success' : function (response) {

                                if(response.includes('N&atilde;o foi poss&iacute;vel estimar o valor do frete')){

                                    let message = 'N&atilde;o foi poss&iacute;vel obter os pre&ccedil;os e prazos de entrega. Tente novamente mais tarte.'
                                    $('.product-shipping .result').removeClass('loading').addClass('loaded').html(`<div class="error-message">${message}</div>`);
                                    
                                    console.log("[[[W3CorpTema]]] productfrete - AJAX - erro no ajax do calculo.");

                                    return;

                                }
                                
                                console.log("[[[W3CorpTema]]] productfrete - AJAX - ajustando tabela.");

                                let shippingRates = $(response.replace(/Prazo de entrega: /gi, ''));
                                let local = shippingRates.find('p .color').html().replace(/\s\s\\\s/g, '').replace(/ \\/g, ',');

                                //shippingRates.find('table:first-child, p, table tr td:first-child').remove();
                                shippingRates.find('table:first-child, p').remove();
                                shippingRates.find('table, table th, table td').removeAttr('align class width border cellpadding cellspacing height colspan');

                                shippingRates.find('table').addClass('shipping-rates-table');

                                var frete = shippingRates.find('table th:first-child').text();
                                if (frete == 'Forma de Envio:'){
                                    shippingRates.find('table th:first-child').html('Frete').attr("colspan", "2");
                                }

                                var valor = shippingRates.find('table th:nth-child(2)').text();
                                if (valor == 'Valor:'){
                                    shippingRates.find('table th:nth-child(2)').html('Valor');
                                }

                                var prazo = shippingRates.find('table th:last-child').text();
                                if (prazo == 'Prazo de Entrega e Observa\u00E7\u00F5es:'){
                                    shippingRates.find('table th:last-child').html('Prazo');
                                }
                                shippingRates = shippingRates.children();

                                $('.product-shipping .result').removeClass('loading').addClass('loaded').html('').append(shippingRates);

                            },
                            'error' : function (request, status, error) {

                                console.log("[[[W3CorpTema]]] productfrete - AJAX - erro ao recuperar valores. ");

                                if(request.responseText !== ''){
                                    console.error(`[[[W3CorpTema]]] - AJAX - productfrete: ${request.responseText}`);
                                }

                                let message = 'N&atilde;o foi poss&iacute;vel obter os pre&ccedil;os e prazos de entrega. Tente novamente mais tarde.'
                                $('.product-shipping .result').removeClass('loading').addClass('loaded').html(`<div class="error-message">${message}</div>`);

                            }
                        });

                    },
                    'error': function (request, status, error) {

                        console.error(`[[[W3CorpTema]]] productfrete - AJAX - Cep nao validado. Error: ${error}`);
                        console.error(`[[[[W3CorpTema]]] productfrete: ${request.responseJSON}`);

                        let message = 'N&atilde;o foi poss&iacute;vel obter os pre&ccedil;os e prazos de entrega. Tente novamente mais tarde.'
                        $('.product-shipping .result').removeClass('loading').addClass('loaded').html(`<div class="error-message">${message}</div>`);

                    }
                });

                return false;

            });

        },






        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - Botao de compra flutuante no mobile
            2024-02-06 | alima
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productButtonFloat: function(){
            if($(window).width() <= this.configs.widthMobile ){
                var floatingButton = $('.js-btn-buy-float');
                var priceDiv = $('.w3-qty');
            
                function isElementInViewport(el) {
                    var rect = el[0].getBoundingClientRect();
                    return (
                        rect.top >= 0 &&
                        rect.left >= 0 &&
                        rect.bottom <= $(window).height() &&
                        rect.right <= $(window).width()
                    );
                }
            
                $(window).scroll(function() {
                    if (isElementInViewport(priceDiv)) {
                        floatingButton.fadeOut();
                    } else {
                        floatingButton.fadeIn();
                    }
                });
                
                
                $(document).on('click', '.js-btn-buy-float', function(){ 
                    var offsetTop = $('#w3-product-info').offset().top - 70;
                    $('html, body').animate({
                        scrollTop: offsetTop
                    }, 'smooth');    
                });


                
                console.log("[[[W3CorpTema]]] productButtonFloat iniciado.");
            }
        },
        


        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - Ajuste de botao de comentarios
            2024-01-08 | tanto
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productWrapBtnComments: function(){
            $('#bt-submit-comments').wrap('<div class="w3-comments-btn"></div>');
            setTimeout(function() {
                $('.w3-comments-btn button').addClass('w3-btn w3-btn-default');
            }, 1000);
    
            console.log("[[[W3CorpTema]]] productWrapBtnComments iniciado.");
        },



        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - Ajuste de botao de comentarios
            2024-01-08 | tanto
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productABtnLogin: function(){
            $('.w3-product-content#coments a[data-logged-user="false"]').addClass('w3-btn w3-btn-featured');
    
            console.log("[[[W3CorpTema]]] productABtnLogin iniciado.");
        },
    


        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - Ajuste de quantidade 
            2024-01-08 | tanto
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productQuant: function(quant){
            var value = parseInt($("#quant").val());
            value+=quant;
            if(value < 1){
                $("#quant").val(1);
            }else{
                $("#quant").val(value);
            }
        
            console.log("[[[W3CorpTema]]] productQuant: adicionado "+quant+" + "+value);
        },
        
        
        
        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - Remove o ALIGN inline da div de precos 
            2024-01-31 | alima
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productPrecoAlignRemove: function(){
            var align = $('.produto-preco #preco');
            // setTimeout(function(){
                align.removeAttr('align');
            // }, 1000);
        
            console.log("[[[W3CorpTema]]] productPrecoAlignRemove iniciado.");
        },



        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - Funcoes que ajustam e trabalham com as Abas
            2024-01-08 | tanto
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productTabs: function(){   
            $(".w3_aba_conteudo_adicional").each(function(){
                let div_conteudo    = $(this);
                let div_id          = div_conteudo.attr("data-div-id");
                console.log(div_id);
                $(div_id).detach().appendTo(div_conteudo);
                $(div_id).show();
                div_conteudo.find('img').attr('loading','lazy');
                div_conteudo.find('iframe').attr('loading','lazy');
            });
            
            $(document).on("click", ".w3-produto-aba-header-clicavel", function(){
                let div_conteudo    = $(this);
                let div_id          = div_conteudo.attr("data-id-aba");
                
                $('.w3_produto_aba_conteudo').hide().removeClass('active');
                $('.w3_produto_aba_conteudo').parent().parent().removeClass('active');
                $('#'+div_id).toggle();
                $(div_conteudo).children('svg').toggleClass('aberto');
                $('.w3-produto-aba-header-clicavel').removeClass('active');
                $(div_conteudo).toggleClass('active');
                $('#'+div_id).parent().parent().addClass('active');
            });
            
            $(".w3_aba_carrega_url").each(function(){
                let div_conteudo    = $(this);
                let div_url          = div_conteudo.attr("data-url");
                console.log(div_url);
                if( div_url.length>0 ){
                    console.log("[[[W3CorpTema]]] productTabs - AJAX - Carregando Aba: ".div_url);
                    $.ajax({
                        'url'     : div_url,
                        'method'  : 'get',
                        'success' : function (response){
                            console.log("[[[W3CorpTema]]] productTabs - AJAX - Aba carregada: ".div_url);
                            if( $(div_conteudo).attr('id')!='aba_conteudo_payment_methods'  ){
                                let html = $(response);
                                html.find('img').attr('loading','lazy');
                                html.find('iframe').attr('loading','lazy');
                                div_conteudo.html(html);
                                
                            } else {
                                let html = $(response);
                                let price         = $('#preco_atual').val();
        
                                html = html.find('#atualizaFormas').unwrap();
                                html = html.find('ul.Forma1').unwrap();
        
                                html.find('li').each(function () {
                                    let image = $('img', this).remove();
                                    $('a', this).prepend(image);
                                });
        
                                html.find('table br').remove();
                                html.find('table td:first-child').remove();
        
                                html.find('table').removeAttr('id class width cellpadding cellspacing border style');
                                html.find('table td, table th').removeAttr('class width style');
                                html.find('li').removeAttr('id style');
                                html.find('li a').removeAttr('id class name');
                                html.find('li a img').removeAttr('border').attr('loading','lazy');
                                
                                html.find('img').attr('loading','lazy');
                                html.find('iframe').attr('loading','lazy');
        
                                html.removeClass().addClass('payment-options');
                                html.find('li').addClass('option');
                                html.find('li a').attr('href', 'javascript:void(0)').attr('rel', 'nofollow, noindex, noreferrer');
                                html.find('table').wrap('<div class="option-details"></div>');
                                html.find('.option-details').css('display', 'none');
        
                                div_conteudo.attr('data-loaded-price', price);
                                div_conteudo.html('').append(html);                        
                            }
                        }
                    });
                }
            });
        
            console.log("[[[W3CorpTema]]] productTabs iniciado.");
        },



        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - Funcao que carrega via AJAX as imagens de uma determinada variacao do produto
            2024-01-08 | tanto
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productLoadVariacaoFotosAjax: function(id){  
            console.log("[[[W3CorpTema]]] productLoadVariacaoFotosAjax - AJAX - Carregando fotos das variacoes"); 
            $.ajax({
                url    : `/web_api/variants/${id}`,
                method : 'get',
                success: function (response){
                    console.log("[[[W3CorpTema]]] productLoadVariacaoFotosAjax - AJAX - Fotos encontradas");
                    let images = response.Variant.VariantImage;
                    
                    if(images.length){
                        w3corptema.productVariacaoFotoCriaGaleria(images);
                    }

                },
                error: function (request, status, error) {
                    console.log(`[[[W3CorpTema]]] productLoadVariacaoFotosAjax - AJAX - encontrou um ERRO! ${error} `);
                }
            });
            
            console.log("[[[W3CorpTema]]] productLoadVariacaoFotosAjax concluido");
        },



        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - Funcao que cria a galeria de imagens de um produto
            2024-01-08 | tanto
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productVariacaoFotoCriaGaleria: function(images){   
            let productName = $('.product-wrapper .product-form .product-name').text();
            let htmlThumbs  = ``;
            let htmlImages  = ``;

            $.each(images, function (index, item){

                let slideIndex = index + 1;

                htmlImages += `
                    <div class="image swiper-slide ${ slideIndex === 1 ? 'active' : '' }" data-index="${slideIndex}">
                        <a data-fancybox="product-gallery" data-src="${item.https}" data-caption="${productName}">
                            <img class="swiper-lazy" src="${item.https}" alt="${productName}">
                        </a>
                    </div>
                    
                `;

                htmlThumbs +=
                    `<li class="swiper-slide ${ slideIndex === 1 ? 'active' : '' }" data-index="${slideIndex}">
                        <div class="thumb">
                            <img src="${item.thumbs[90].https}" alt="${productName}">
                        </div>
                    </li>
                `;

            });


            $('.w3-product .w3-product-gallery .swiper-wrapper .image').remove();
            $('.product-wrapper .product-gallery .product-thumbs .swiper-slide').remove();
            $('.w3-product .w3-product-gallery .swiper-wrapper').html(htmlImages);

            if(images.length > 1){

                $('.w3-product .w3-product-gallery .swiper-wrapper .product-thumbs').addClass('show');
                $('.w3-product .w3-product-gallery .swiper-wrapper .thumbs-list .swiper-wrapper').html(htmlThumbs);

            } else {
                $('.w3-product .w3-product-gallery .swiper-wrapper.product-thumbs').removeClass('show');
            }
            
            console.log("[[[W3CorpTema]]] productLoadVariacaoFotosAjax concluido para id "+id+".");
        },



        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Produto - Funcao que observa os clicks para ajustar as imagens da galeria de um produto
            2024-01-08 | tanto
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        productVariacaoFoto: function(){   
            
            $('.product-variants').on('click', '.lista_cor_variacao li[data-id]', function(){
                w3corptema.productLoadVariacaoFotosAjax($(this).data('id'));
                console.log('click1');
            });

            $('.product-variants').on('click', '.lista-radios-input', function(){
                w3corptema.productLoadVariacaoFotosAjax($(this).find('input').val());
                console.log('click2');
            });

            $('.product-variants').on('change', 'select', function(){
                w3corptema.productLoadVariacaoFotosAjax($(this).val());
                console.log('click3');
            });

            $('.product-variants').on('change', '.infoSelects', function(){
                 console.log('click4');
                var optionSelected = $(this).find('option:selected');
                if (optionSelected.val().length){
                    var rel = optionSelected.attr('rel');
                    var image = [
                        {
                            https: rel,
                            thumbs: {
                                    90: {
                                        https: rel,
                                    },
                            }
                        },
                    ];
                    w3corptema.productVariacaoFotoCriaGaleria(image);
                }
            });
        
            console.log("[[[W3CorpTema]]] productVariacaoFoto iniciado.");
        },


        /* .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-
            FUNCAO: Page Contact - Funcao que monta a pg contato
            2024-10-02 | alima
        .-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.-.- */
        contactContructorPage: function(){   
            
            // Seleciona todos os filhos de .w3-page-contact .w3-site-main .container3:last-of-type > .container2
            $('.w3-page-contact .w3-site-main .container3:last-of-type > .container2 > *').each(function(index) {
                // Adiciona a classe .child com nÃÂÃÂÃÂÃÂºmero sequencial
                $(this).addClass('child' + (index + 1));
            });
            
            // Wrap child1 atÃÂÃÂÃÂÃÂ© child6 com .contact1
            $('.w3-page-contact .w3-site-main .container3:last-of-type > .container2 > .child1, .child2, .child3, .child4, .child5, .child6').wrapAll('<div class="contact1"></div>');
            
            // Wrap child7 com .contactForm
            $('.w3-page-contact .w3-site-main .container3:last-of-type > .container2 > .child7').wrap('<div class="contactForm"></div>');
            
            // Wrap child8 atÃÂÃÂÃÂÃÂ© child11 com .contact2
            $('.w3-page-contact .w3-site-main .container3:last-of-type > .container2 > .child8, .child9, .child10, .child11').wrapAll('<div class="contact2"></div>');
            
            
            // Adiciona as classes .w3-btn e .w3-btn-featured ao elemento .btn_submit dentro de .contactForm
            $('.contactForm .btn_submit').addClass('w3-btn w3-btn-featured');


            console.log("[[[W3CorpTema]]] contactContructorPage iniciado.");
        }






    }
    
    
    
    
    
    
    
    
    
    
    
    

    //Inicializacao das funcoes do tema
    
    $(function(){

        //Funcoes de configuracao e uso geral
        w3corptema.inicializa();
        w3corptema.smoothScroll();
        w3corptema.btnMenu();
        w3corptema.btnHeader();
        w3corptema.btnToTop();
        w3corptema.menuMobile();
        w3corptema.menuMobileCat();
        w3corptema.btnMenuMobile();
        w3corptema.inicializaSwiper();
        w3corptema.atualizaContadoresRegressivos();
        w3corptema.inicializaMenuTopo();
        w3corptema.formControl();
        w3corptema.inicializaCarrinho();
        w3corptema.btnNox();
        


        //Funcoes que necessitam de um leve delay para evitar problemas
        setTimeout(function(){
            w3corptema.atualizarAlturaDivHeader();
        },20);



        //Funcoes acionadas no resize
        $(window).on("resize", function() {
            //w3corptema.atualizarAlturaDivHeader();
        });



        //Funcoes acionadas no resize - o ideal eh replicar tambem na inicializacao
        $(window).on("scroll", function() {
            w3corptema.scrollHeaderFloat();
            w3corptema.scrollbtnToTop();
        });



        //Funcoes especiicas para cada pagina
        if($('html').hasClass('page-home')){
            setTimeout(function(){
                w3corptema.homeNewsLoad();
            },200);
                      
            

        } else if($('html').hasClass('page-newsletter')){
            


        } else if($('html').hasClass('page-catalog') || $('html').hasClass('page-search')){
            w3corptema.catalogLayout();
            if($('body').hasClass('w3-ctrl-menu-hide')){
                w3corptema.catalogFilterHide();    
            } else{
                w3corptema.catalogFilterMobile();
            }



        } else if($('html').hasClass('page-product')){
            w3corptema.productWrapBtnComments();
            w3corptema.productABtnLogin();
            //w3corptema.productQuant();
            w3corptema.productTabs();
            //w3corptema.productVariacaoFoto();
            w3corptema.productPrecoAlignRemove();
            w3corptema.productMeasureTable();
            w3corptema.productButtonFloat();
            w3corptema.productVariantAccordion();
            w3corptema.productVariantTexts();
            w3corptema.productfrete();
            w3corptema.productDescription();
            



        } else if ($('html').hasClass('page-busca_noticias')){



        } else if ($('html').hasClass('page-noticia')){
            


        } else if ($('html').hasClass('page-depoimentos')){



        } else if($('html').hasClass('page-contact')){
            w3corptema.contactContructorPage();


        } else if($('html').hasClass('page-finalizar_presentes')){
            


        }  
    
    });


}(jQuery));
